# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored — never commit secrets.

# Supabase: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used in `app/api/**` route handlers via `lib/supabase/server.ts`.
# Never import this into a client component.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI: https://platform.openai.com/api-keys (search / summarize routes)
OPENAI_API_KEY=

# OpenRouter: https://openrouter.ai/keys — used for session chat replies
OPENROUTER_API_KEY=
# Optional. Default: nvidia/nemotron-nano-9b-v2:free
OPENROUTER_CHAT_MODEL=
# Optional; OpenRouter asks for an HTTP referer on some accounts
OPENROUTER_HTTP_REFERER=
